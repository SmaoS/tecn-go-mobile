{
  "expo": {
    "name": "TecnGo",
    "slug": "tecngo",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "scheme": "tecngo",
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "TecnGo usa la cámara para capturar tu foto de perfil y evidencias."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TecnGo usa tu ubicación para buscar servicios técnicos cercanos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TecnGo usa tus fotos para completar tu perfil y evidencias."
        }
      ],
      "sentry-expo"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tecngo.app",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.tecngo",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00D84A"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020817"
    }
  }
}
