{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_ENFORCE_VERSION_CHECK": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_ENFORCE_VERSION_CHECK": "false"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "cache": {
        "disabled": true
      },
      "env": {
        "EXPO_PUBLIC_ENFORCE_VERSION_CHECK": "true",
        "SENTRY_UPLOAD_SOURCEMAPS": "false"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
